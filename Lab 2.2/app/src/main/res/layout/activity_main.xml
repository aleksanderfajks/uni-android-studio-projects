<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="Główny tekst" />

    <TextView
        android:id="@+id/text_a1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="a)" />

    <TextView
        android:id="@+id/text_a2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="a)" />

    <TextView
        android:id="@+id/text_b1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/textMain"
        android:layout_marginStart="80dp"
        android:layout_marginBottom="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="b)" />

    <TextView
        android:id="@+id/text_b2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textMain"
        android:layout_marginStart="80dp"
        android:layout_marginTop="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="b)" />

    <TextView
        android:id="@+id/text_c1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/textMain"
        android:layout_alignStart="@id/textMain"
        android:layout_marginStart="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="c)" />

    <TextView
        android:id="@+id/text_c2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textMain"
        android:layout_alignEnd="@id/textMain"
        android:layout_marginEnd="10dp"
        android:background="#00FFBB"
        android:padding="5dp"
        android:text="c)" />

</RelativeLayout>