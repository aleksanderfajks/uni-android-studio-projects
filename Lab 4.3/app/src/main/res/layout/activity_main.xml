<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/ivHeader"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@drawable/kostki_zdjecie"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnRzuc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RZUĆ KOSTKĄ!"
        android:backgroundTint="#6200EE"
        android:textColor="@android:color/white" />

    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/givKostka"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:visibility="invisible"
        android:src="@drawable/kostkagif" />

    <ImageView
        android:id="@+id/ivWynikKostka"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        tools:src="@drawable/dice1" />

    <TextView
        android:id="@+id/tvWynik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        android:gravity="center"
        android:visibility="invisible" />

</LinearLayout>
